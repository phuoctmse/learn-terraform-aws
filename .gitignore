# Terraform local cache
.terraform/

# Terraform state (do not commit)
*.tfstate
*.tfstate.*

# Sensitive variable files
*.tfvars
*.tfvars.json

# CLI config files
.terraformrc
terraform.rc

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json